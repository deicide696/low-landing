# Supabase (obtener en: supabase.com → tu proyecto → Settings → API)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google OAuth Client ID (Google Cloud Console → Credentials → OAuth 2.0 Client ID)
# El Client Secret va SOLO en los secrets de la Edge Function, NUNCA aquí
VITE_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# Microsoft OAuth Application (Client) ID (Azure Portal → App Registrations)
# El Client Secret va SOLO en los secrets de la Edge Function, NUNCA aquí
VITE_MICROSOFT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# URL de la app (cambiar a dominio de producción al desplegar)
VITE_APP_URL=http://localhost:5173
